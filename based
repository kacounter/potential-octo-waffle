<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<title>2061 Countdown</title>
<style>
body{
    margin:0;
    display:flex;
    justify-content:center;
    align-items:center;
    height:100vh;
    background:#000;
    color:#fff;
    font-family:Arial,sans-serif;
    text-align:center;
}
h1{
    font-size:2rem;
    margin-bottom:20px;
}
#countdown{
    font-size:5rem;
    font-weight:bold;
}
</style>
</head>
<body>
<div>
    <h1>Countdown to June 10, 2061</h1>
    <div id="countdown"></div>
</div>

<script>
const target = new Date("2061-06-10");

function updateCountdown() {
    const now = new Date();

    let years = target.getFullYear() - now.getFullYear();
    let anniversary = new Date(now);
    anniversary.setFullYear(now.getFullYear() + years);

    if (anniversary > target) {
        years--;
        anniversary.setFullYear(now.getFullYear() + years);
    }

    const days = Math.floor(
        (target - anniversary) / (1000 * 60 * 60 * 24)
    );

    document.getElementById("countdown").textContent =
        `${years} Years • ${days} Days`;
}

updateCountdown();
setInterval(updateCountdown, 60000);
</script>
</body>
</html>
